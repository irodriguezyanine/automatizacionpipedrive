# Pipedrive API (obligatorio)
# En Pipedrive: Configuración > API > Token personal
PIPEDRIVE_API_TOKEN=tu-token-aqui
PIPEDRIVE_API_BASE=https://api.pipedrive.com

# AWS SES – mismos nombres que en TasacionesVedisa/.env (copia los valores de ahí)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Envío por Gmail (recomendado para no afectar vedisaremates.cl) ---
# Si defines GMAIL_USER y GMAIL_APP_PASSWORD, los correos se envían desde Gmail en lugar de SES.
# Crear Contraseña de aplicación: cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones.
GMAIL_USER=comercialvedisaremates@gmail.com
GMAIL_APP_PASSWORD=

# CC obligatorio en todos los envíos (siempre se agrega este correo en copia).
EMAIL_CC_COMERCIAL=comercial@vedisaremates.cl

# Ruta del PDF de presentación para adjuntar (opcional). Por defecto: attachments/2603 Presentación VEDISA REMATES.pdf
# ATTACHMENT_PRESENTATION_PATH=attachments/2603 Presentación VEDISA REMATES.pdf

# --- Envío por AWS SES (sin Gmail; no usar @vedisaremates.cl si quieres proteger el dominio) ---
# Remitentes: deben estar VERIFICADOS en AWS SES (consola SES → Identities → Create).
# Para no arriesgar tu dominio, verifica un Gmail en SES y úsalo aquí (el envío va por AWS, no por Gmail).
EMAIL_FROM_COMERCIAL=comercialvedisaremates@gmail.com
EMAIL_FROM_IRODRIGUEZ=comercialvedisaremates@gmail.com
# Nombre que ve el destinatario (opcional)
EMAIL_FROM_DISPLAY_NAME=Vedisa Remates

# Opcional: Configuration Set de SES para tracking (como en TasacionesVedisa)
# SES_CONFIGURATION_SET=vedisa-email-tracking

# Panel (Vercel): contraseña para acceder al panel de administración
# ADMIN_PASSWORD=tu-contraseña-segura
